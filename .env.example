# Database Configuration
DB_URL=jdbc:postgresql://your-db-host:port/database?sslmode=require&prepareThreshold=0
DB_USERNAME=your_database_username_here
DB_PASSWORD=your_database_password_here

# Gemini API Configuration
GEMINI_API_KEY=your_gemini_api_key_here

# Admin Configuration
# Generate a BCrypt value and paste only the hash. Do not store the plain password.
ADMIN_USERNAME=admin
ADMIN_PASSWORD_HASH=$2a$12$replace_with_bcrypt_hash
# Backward-compatible fallback for old deploy secrets only.
ADMIN_PASSWORD=
ADMIN_LOGIN_MAX_FAILURES=5
ADMIN_LOGIN_LOCK_MINUTES=10

# Use SameSite=None and Secure=true only when the frontend and backend are on different HTTPS origins.
SESSION_COOKIE_SECURE=false
SESSION_COOKIE_SAME_SITE=lax
